<script>
  function filterReviews(type, btn) {
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active','active-pos','active-neg'));
    btn.classList.add('active');

    const allCards = document.querySelectorAll('.review-card');
    const posSection = document.querySelector('[data-section="positive"]');
    const negSection = document.querySelector('[data-section="negative"]');
    const seps = document.querySelectorAll('.section-sep');

    if (type === 'all') {
      allCards.forEach(c => c.style.display = '');
      posSection.style.display = '';
      negSection.style.display = '';
      seps.forEach(s => s.style.display = '');
    } else if (type === 'positive') {
      document.querySelectorAll('.review-card.positive').forEach(c => c.style.display = '');
      document.querySelectorAll('.review-card.negative').forEach(c => c.style.display = 'none');
      posSection.style.display = '';
      negSection.style.display = 'none';
      seps.forEach(s => s.style.display = '');
      btn.classList.remove('active');
      btn.classList.add('active-pos');
    } else if (type === 'negative') {
      document.querySelectorAll('.review-card.negative').forEach(c => c.style.display = '');
      document.querySelectorAll('.review-card.positive').forEach(c => c.style.display = 'none');
      posSection.style.display = 'none';
      negSection.style.display = '';
      seps.forEach(s => s.style.display = '');
      btn.classList.remove('active');
      btn.classList.add('active-neg');
    }
  }
</script>
